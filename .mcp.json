{
  "mcpServers": {
    "session_recall": {
      "title": "Session Recall",
      "description": "Search local sessions by remembered content and return links for going back to them.",
      "icons": [
        {
          "src": "./assets/logo.svg",
          "mimeType": "image/svg+xml",
          "sizes": [
            "24x24"
          ]
        },
        {
          "src": "./assets/icon.png",
          "mimeType": "image/png",
          "sizes": [
            "256x256"
          ]
        }
      ],
      "cwd": ".",
      "command": "bash",
      "args": [
        "./scripts/start-mcp.sh"
      ],
      "startup_timeout_sec": 120
    }
  }
}
